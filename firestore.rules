rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthed() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper : vérifie qu'un diff ne touche QUE des champs autorisés
    function affectsOnly(allowedKeys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedKeys);
    }

    // ============================================================
    // Users
    // ============================================================
    //
    // ⚠️ AUDIT (V2 conseillée) :
    // Actuellement, tout user connecté peut lire le doc complet d'un autre user
    // (email, role, tier, stripeCustomerId, etc.). Pour durcir :
    //   - Créer une collection `users_public/{uid}` avec uniquement {name, avatar, joinedAt, tier}
    //   - Restreindre `users/{uid}` à `request.auth.uid == uid || isAdmin()`
    //   - Migrer le code qui lit `users/X.name` vers `users_public/X.name`
    // À planifier dans une migration séparée.
    match /users/{uid} {
      allow read: if isAuthed();
      allow write: if isAuthed() && (request.auth.uid == uid || isAdmin());

      // Sous-collections (profs, friends, decks, games, push_subs…)
      // ⚠️ AUDIT : règle trop permissive (read par tout connecté). Voir TODO ci-dessus.
      match /{subcollection}/{doc} {
        allow read: if isAuthed();
        allow write: if isAuthed() && (request.auth.uid == uid || isAdmin() || request.auth.uid == doc);
      }
    }

    // Push subscriptions : durcissement spécifique — seul l'owner peut lire/écrire
    match /users/{uid}/push_subs/{subId} {
      allow read, write: if isAuthed() && request.auth.uid == uid;
    }

    // Notifications sociales : créables par n'importe quel user (sous condition de kind),
    // lisibles uniquement par le destinataire.
    match /users/{uid}/social_notifs/{notifId} {
      allow read, update, delete: if isAuthed() && request.auth.uid == uid;
      allow create: if isAuthed()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.get('kind', '') in ['like','comment','follow','new_deck']
        && request.resource.data.text is string == false
           || (request.resource.data.text is string && request.resource.data.text.size() < 500);
    }

    // ============================================================
    // Meta : lecture pour tous les connectés, écriture admin seulement
    // ============================================================
    match /meta/{doc} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // ============================================================
    // Notifications transactionnelles (trades, friends, arena, etc.)
    // ============================================================
    match /notifications/{notifId} {
      // Durci : lecture par destinataire, expéditeur ou admin seulement
      allow read: if isAuthed() && (
        request.auth.uid == resource.data.get('targetUid', '') ||
        request.auth.uid == resource.data.get('fromUid', '') ||
        isAdmin()
      );
      allow create: if isAuthed() && (
        isAdmin() ||
        (request.resource.data.get('type', '') in [
          'trade', 'trade_accepted', 'trade_declined',
          'friend_request', 'friend_accepted',
          'arena_invite', 'list_invite', 'pod_invite', 'bet_event'
        ] && request.resource.data.targetUid is string)
      );
      allow delete: if isAdmin() || (isAuthed() && (
        request.auth.uid == resource.data.get('targetUid', '') ||
        request.auth.uid == resource.data.get('fromUid', '')
      ));
      allow update: if isAuthed() && (
        affectsOnly(['readBy']) ||
        affectsOnly(['dismissedBy']) ||
        affectsOnly(['readBy','dismissedBy']) ||
        (resource.data.get('type', '') == 'friend_request' &&
         request.auth.uid == resource.data.targetUid &&
         affectsOnly(['status', 'readBy']))
      );
    }

    // ============================================================
    // Trades : lecture/écriture pour les participants
    // ============================================================
    match /trades/{tradeId} {
      allow read: if isAuthed() &&
        request.auth.uid in resource.data.participants;
      allow create: if isAuthed() &&
        request.resource.data.fromUid == request.auth.uid &&
        request.auth.uid in request.resource.data.participants;
      allow update: if isAuthed() &&
        request.auth.uid in resource.data.participants;
      allow delete: if isAuthed() &&
        resource.data.fromUid == request.auth.uid;
    }

    // ============================================================
    // Arena rooms : durci pour limiter aux participants quand possible
    // ============================================================
    //
    // Le schéma actuel n'a pas systématiquement de champ `players`/`participants` —
    // on garde donc une règle permissive sur create/read mais on durcit update/delete
    // pour empêcher un user externe d'effacer une partie en cours.
    match /arena_rooms/{roomId} {
      allow read: if isAuthed();
      allow create: if isAuthed() &&
        request.resource.data.get('hostUid', request.auth.uid) == request.auth.uid;
      allow update: if isAuthed(); // un participant peut updater son état
      allow delete: if isAuthed() && (
        resource.data.get('hostUid', '') == request.auth.uid || isAdmin()
      );
    }

    // ============================================================
    // Pods / paris / draft : idem — permissif mais delete protégé
    // ============================================================
    match /pods/{podId} {
      allow read, create, update: if isAuthed();
      allow delete: if isAuthed() && (
        resource.data.get('hostUid', '') == request.auth.uid ||
        resource.data.get('createdBy', '') == request.auth.uid ||
        isAdmin()
      );
    }
    match /bets/{betId} {
      allow read, create, update: if isAuthed();
      allow delete: if isAuthed() && (
        resource.data.get('createdBy', '') == request.auth.uid || isAdmin()
      );
    }
    match /limited_rooms/{roomId} {
      allow read, create, update: if isAuthed();
      allow delete: if isAuthed() && (
        resource.data.get('hostUid', '') == request.auth.uid || isAdmin()
      );
    }

    // ============================================================
    // Listes d'achat partagées (Cardmarket)
    // ============================================================
    match /shared_lists/{listId} {
      allow read, update, delete: if isAuthed() &&
        request.auth.uid in resource.data.members;
      allow create: if isAuthed() &&
        request.auth.uid in request.resource.data.members &&
        request.resource.data.createdBy == request.auth.uid;
    }

    // ============================================================
    // Decks publics : lecture pour tout le monde (même anonyme)
    // ============================================================
    //
    // - création/delete/full-update : créateur ou admin
    // - update partielle (likes/comments) : tout user connecté, sous validation
    //   stricte des types pour empêcher l'abus (compteur négatif, payload géant…)
    match /public_decks/{deckId} {
      allow read: if true;

      allow create: if isAuthed()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() < 200
        && request.resource.data.get('rawName', '').size() < 15000
        && request.resource.data.get('cardCount', 0) < 1000;

      allow delete: if isAuthed() && (
        resource.data.createdBy == request.auth.uid || isAdmin()
      );

      // Update : 3 cas autorisés
      //   1. Créateur : peut tout modifier
      //   2. Admin : modération
      //   3. Tout user connecté : uniquement champs sociaux, avec validation
      allow update: if isAuthed() && (
        resource.data.createdBy == request.auth.uid ||
        isAdmin() ||
        (
          affectsOnly(['likes', 'likedBy', 'comments']) &&
          // Validation : likes reste dans une plage raisonnable
          request.resource.data.get('likes', 0) >= 0 &&
          request.resource.data.get('likes', 0) < 1000000 &&
          // Validation : likedBy taille raisonnable
          request.resource.data.get('likedBy', []).size() < 10000 &&
          // Validation : comments taille raisonnable
          request.resource.data.get('comments', []).size() < 500
        )
      );
    }

    // ============================================================
    // Commandants (catalogue Scryfall seedé pour SEO)
    // ============================================================
    // Lecture publique pour les pages /c/:slug. Écriture par admin seulement
    // (ou via script avec une clé service account Firebase Admin SDK).
    match /commanders/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // Combos (catalogue seedé pour pages /combo/:slug)
    // ============================================================
    match /combos/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // Marketplace P2P (carte à échanger / recherche par user)
    // ============================================================
    // Chaque user gère son propre doc /marketplace/{uid} : offering + searching
    // Lecture publique pour permettre le matching cross-user.
    match /marketplace/{uid} {
      allow read: if true;
      allow write: if isAuthed() && request.auth.uid == uid;
    }

    // ============================================================
    // Play Rooms (Remote Play companion)
    // ============================================================
    // Rooms de partie multi-joueurs synchronisées via room code à 6 chars.
    // Lecture publique (les joueurs scannent le code), création par tout user auth.
    match /play_rooms/{code} {
      allow read: if true;
      allow create: if isAuthed();
      allow update: if isAuthed();
      allow delete: if isAuthed() && resource.data.host == request.auth.uid;
    }

    // ============================================================
    // Tournaments (Organizer multi-device)
    // ============================================================
    // L'organisateur peut écrire. Les joueurs peuvent lire pour suivre.
    match /tournaments/{tid} {
      allow read: if true;
      allow create: if isAuthed();
      allow update: if isAuthed() && (
        resource.data.organizer == request.auth.uid ||
        // Les joueurs peuvent reporter leur match
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rounds', 'updatedAt'])
      );
      allow delete: if isAuthed() && resource.data.organizer == request.auth.uid;
    }

    // ============================================================
    // DCI Rankings (classement global anonymisé)
    // ============================================================
    // Chaque user écrit son propre rating. Lecture publique pour leaderboard.
    match /dci_rankings/{uid} {
      allow read: if true;
      allow write: if isAuthed() && request.auth.uid == uid &&
        request.resource.data.keys().hasOnly(['displayName', 'elo', 'games', 'wins', 'losses', 'byFormat', 'updatedAt']);
    }

    // ============================================================
    // Cache d'effets de cartes (Arena Pro rules engine)
    // ============================================================
    // Stocke les actions JSON parsées par l'IA pour chaque carte.
    // Partagé entre tous les users pour réduire les appels API LLM.
    // Données non-sensibles (juste oracle text → JSON d'actions).
    // Lecture publique + écriture publique limitée (validation taille).
    match /card_effects/{slug} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasOnly(['actions', 'ts']) &&
        request.resource.data.actions is string &&
        request.resource.data.actions.size() < 10000;
      allow update: if
        request.resource.data.keys().hasOnly(['actions', 'ts']) &&
        request.resource.data.actions is string &&
        request.resource.data.actions.size() < 10000;
      allow delete: if isAdmin();
    }

    // ============================================================
    // Stats globales communauté (page publique indexable)
    // ============================================================
    // Doc unique meta/stats avec compteurs publics (nb decks publics,
    // nb utilisateurs actifs, top commandants…). Calculé par cron.
    match /community_stats/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // Reports (modération communautaire) — pas encore branché côté UI
    // ============================================================
    match /reports/{reportId} {
      allow create: if isAuthed() &&
        request.resource.data.fromUid == request.auth.uid &&
        request.resource.data.reason is string &&
        request.resource.data.reason.size() < 1000;
      allow read, update, delete: if isAdmin();
    }
  }
}
