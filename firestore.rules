rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthed() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users: tout utilisateur connecté peut lire, chaque utilisateur ou admin écrit son propre document
    match /users/{uid} {
      allow read: if isAuthed();
      allow write: if isAuthed() && (request.auth.uid == uid || isAdmin());

      // Sous-collections (profs, friends, decks, games…) : propriétaire, admin, ou le doc lui-même (ex: retrait ami)
      match /{subcollection}/{doc} {
        allow read: if isAuthed();
        allow write: if isAuthed() && (request.auth.uid == uid || isAdmin() || request.auth.uid == doc);
      }
    }

    // Meta : lecture pour tous les connectés, écriture admin seulement
    match /meta/{doc} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && (
        isAdmin() ||
        (request.resource.data.get('type', '') in [
          'trade', 'trade_accepted', 'trade_declined',
          'friend_request', 'friend_accepted',
          'arena_invite', 'list_invite', 'pod_invite'
        ] && request.resource.data.targetUid is string)
      );
      allow delete: if isAdmin();
      // Marquer comme lu (readBy uniquement) ou supprimer pour soi (dismissedBy) : tout utilisateur connecté
      // Accepter/refuser une demande d'ami (status + readBy) : le destinataire uniquement
      allow update: if isAuthed() && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dismissedBy']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy','dismissedBy']) ||
        (resource.data.get('type', '') == 'friend_request' &&
         request.auth.uid == resource.data.targetUid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'readBy']))
      );
    }

    // Trades : lecture/écriture pour les participants
    match /trades/{tradeId} {
      allow read: if isAuthed() &&
        request.auth.uid in resource.data.participants;
      allow create: if isAuthed() &&
        request.resource.data.fromUid == request.auth.uid &&
        request.auth.uid in request.resource.data.participants;
      allow update: if isAuthed() &&
        request.auth.uid in resource.data.participants;
      allow delete: if isAuthed() &&
        resource.data.fromUid == request.auth.uid;
    }

    // Arena rooms : lecture/écriture pour tout utilisateur connecté
    match /arena_rooms/{roomId} {
      allow read, write: if isAuthed();
    }

    // Pods / sessions de jeu planifiées : lecture/écriture pour tout utilisateur
    // connecté (chaque participant doit pouvoir poser son RSVP)
    match /pods/{podId} {
      allow read, write: if isAuthed();
    }

    // Listes d'achat partagées : lecture/écriture pour les membres
    match /shared_lists/{listId} {
      allow read, update, delete: if isAuthed() &&
        request.auth.uid in resource.data.members;
      allow create: if isAuthed() &&
        request.auth.uid in request.resource.data.members &&
        request.resource.data.createdBy == request.auth.uid;
    }

    // Decks publics : lecture pour tout le monde (même anonyme), écriture pour le
    // propriétaire ; tout utilisateur connecté peut aimer / commenter (likes + comments)
    match /public_decks/{deckId} {
      allow read: if true;
      allow create: if isAuthed() && request.resource.data.createdBy == request.auth.uid;
      allow delete: if isAuthed() && resource.data.createdBy == request.auth.uid;
      allow update: if isAuthed() && (
        resource.data.createdBy == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'comments'])
      );
    }
  }
}
