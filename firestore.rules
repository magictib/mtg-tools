rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthed() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users: tout utilisateur connecté peut lire, chaque utilisateur écrit son propre document
    match /users/{uid} {
      allow read: if isAuthed();
      allow write: if isAuthed() && request.auth.uid == uid;
    }

    // Profs (sous-collection) : propriétaire uniquement
    match /users/{uid}/profs/{doc} {
      allow read: if isAuthed();
      allow write: if isAuthed() && request.auth.uid == uid;
    }

    // Meta : lecture pour tous les connectés, écriture admin seulement
    match /meta/{doc} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // Notifications : broadcast (sans targetUid) ou ciblées
    match /notifications/{notifId} {
      allow read: if isAuthed();
      allow create: if isAdmin() ||
        (isAuthed() && request.resource.data.get('type', '') in ['trade', 'trade_accepted', 'trade_declined'] &&
         request.resource.data.targetUid is string);
      allow delete: if isAdmin();
      allow update: if isAuthed() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']);
    }

    // Trades : lecture/écriture pour les participants
    match /trades/{tradeId} {
      allow read: if isAuthed() &&
        request.auth.uid in resource.data.participants;
      allow create: if isAuthed() &&
        request.resource.data.fromUid == request.auth.uid &&
        request.auth.uid in request.resource.data.participants;
      allow update: if isAuthed() &&
        request.auth.uid in resource.data.participants;
      allow delete: if isAuthed() &&
        resource.data.fromUid == request.auth.uid;
    }

    // Arena rooms : lecture/écriture pour tout utilisateur connecté
    match /arena_rooms/{roomId} {
      allow read, write: if isAuthed();
    }
  }
}
