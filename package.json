{
  "name": "manalab",
  "version": "1.0.0",
  "description": "ManaLAB — Gestion de collection Magic: The Gathering",
  "main": "electron/main.js",
  "author": "Thibaud",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --publish never",
    "release": "electron-builder --win --publish always"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-log": "^5.1.2",
    "electron-updater": "^6.1.8"
  },
  "build": {
    "appId": "com.manalab.desktop",
    "productName": "ManaLAB",
    "copyright": "Copyright © 2025 Thibaud",
    "files": [
      "index.html",
      "sw.js",
      "manifest.json",
      "icon.svg",
      "electron/main.js",
      "electron/preload.js",
      "electron/icon.png"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "electron/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ManaLAB",
      "installerHeaderIcon": "electron/icon.png",
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "magictib",
      "repo": "mtg-tools"
    }
  }
}
